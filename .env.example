# .env.example — copy to .env and fill in values

# Notion MCP remote URL
NOTION_MCP_URL=https://mcp.notion.com/mcp

# Groq API key used for spec extraction, diagnosis, and fallback code generation
# Get at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Populated automatically by: node index.js init
# Do not set manually
NOTION_DATABASE_ID=
NOTION_SPEC_PAGE_ID=

# Parent page used by init to create the database + template page
# The authenticated Notion MCP user must have access to this page
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# Port for the Express server (default: 3001)
PORT=3001
